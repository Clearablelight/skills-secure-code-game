{
  "name": "envguard",
  "version": "1.0.0",
  "description": "Type-safe, validated environment variables for Node.js",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
